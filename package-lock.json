{
  "name": "botcha-cli",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@botcha/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@botcha/sdk": {
      "resolved": "packages/sdk",
      "link": true
    },
    "node_modules/@botcha/types": {
      "resolved": "packages/types",
      "link": true
    },
    "packages/cli": {
      "name": "@botcha/cli",
      "version": "0.0.0",
      "license": "MIT"
    },
    "packages/sdk": {
      "name": "@botcha/sdk",
      "version": "0.0.0",
      "license": "MIT"
    },
    "packages/types": {
      "name": "@botcha/types",
      "version": "0.0.0",
      "license": "MIT"
    }
  }
}
